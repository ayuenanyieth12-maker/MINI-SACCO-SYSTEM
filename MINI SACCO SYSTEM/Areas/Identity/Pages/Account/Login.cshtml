@* @page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<h1>@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-4">
        <section>
            <form id="account" method="post">
                <h2>Use a local account to log in.</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                <div>
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>Use another service to log in.</h3>
            <hr />
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div>
                        <p>
                            There are no external authentication services configured. See this <a href="https://go.microsoft.com/fwlink/?LinkID=532715">article
                            about setting up this ASP.NET application to support logging in via external services</a>.
                        </p>
                    </div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div>
                            <p>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                                }
                            </p>
                        </div>
                    </form>
                }
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} *@


@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Mini SACCO</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background-color: #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            padding: 1rem;
        }

        .login-card {
            background: #ffffff;
            border-radius: 16px;
            border: 0.5px solid #e9ecef;
            padding: 2.5rem 2rem;
        }

        .login-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
            justify-content: center;
        }

        .login-brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background-color: #1a3c5e;
            color: #e8a838;
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-brand-name {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .login-title {
            font-size: 22px;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 4px;
            text-align: center;
        }

        .login-sub {
            font-size: 13px;
            color: #6c757d;
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-label {
            font-size: 13px;
            font-weight: 500;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .login-input {
            font-size: 13px;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 10px 14px;
            width: 100%;
            outline: none;
            transition: border 0.2s;
        }

            .login-input:focus {
                border-color: #1a3c5e;
                box-shadow: 0 0 0 3px rgba(26, 60, 94, 0.08);
            }

        .login-btn {
            background-color: #1a3c5e;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            padding: 10px;
            font-size: 14px;
            font-weight: 500;
            width: 100%;
            cursor: pointer;
            transition: background 0.2s;
        }

            .login-btn:hover {
                background-color: #16324f;
            }

        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 12px;
            color: #6c757d;
        }

        .accent-bar {
            height: 4px;
            background: #e8a838;
            border-radius: 16px 16px 0 0;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="accent-bar"></div>
        <div class="login-card">

            <div class="login-brand">
                <div class="login-brand-icon">S</div>
                <span class="login-brand-name">Mini SACCO</span>
            </div>

            <div class="login-title">Welcome back</div>
            <div class="login-sub">Sign in to your admin account</div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label class="login-label">Email address</label>
                    <input asp-for="Input.Email"
                           class="login-input"
                           autocomplete="username"
                           placeholder="admin@minisacco.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="login-label">Password</label>
                    <input asp-for="Input.Password"
                           class="login-input"
                           type="password"
                           autocomplete="current-password"
                           placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="login-btn">Sign in</button>
            </form>

            <div class="login-footer">
                Mini SACCO System &copy; @DateTime.Now.Year
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
