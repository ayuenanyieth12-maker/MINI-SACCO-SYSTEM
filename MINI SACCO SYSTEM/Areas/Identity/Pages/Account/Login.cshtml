@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width: 460px; margin: 60px auto;">
    <div class="card border-0 shadow-sm p-4">

        <div class="text-center mb-4">
            <div style="width:52px; height:52px; background:#1a2e4a; border-radius:12px; display:flex; align-items:center; justify-content:center; margin: 0 auto 12px;">
                <span style="color:white; font-size:1.4rem; font-weight:700;">S</span>
            </div>
            <h4 class="fw-bold mb-1">Welcome back</h4>
            <p class="text-muted small">Login to your Mini SACCO account</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold small">Email address</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username"
                       placeholder="you@example.com" style="padding: 10px 14px;" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label fw-semibold small">Password</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                       placeholder="Enter your password" style="padding: 10px 14px;" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <label class="d-flex align-items-center gap-2 small text-muted" style="cursor:pointer;">
                    <input class="form-check-input m-0" asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
                <a asp-page="./ForgotPassword" class="small text-success">Forgot password?</a>
            </div>

            <button id="login-submit" type="submit" class="btn w-100 fw-semibold"
                    style="background:#1a2e4a; color:white; padding:12px;">
                Login
            </button>
        </form>

        <div class="text-center mt-3">
            <small class="text-muted">
                Don't have an account?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                   class="text-success fw-semibold">Register here</a>
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}