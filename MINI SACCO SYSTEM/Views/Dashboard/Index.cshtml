@using MINI_SACCO_SYSTEM.Models
@using MINI_SACCO_SYSTEM.ViewModels

@{
    ViewData["Title"] = "Dashboard";
    var report = ViewBag.Report as ReportViewModel;
    var members = ViewBag.RecentMembers as List<Members>;
    var loans = ViewBag.ActiveLoans as List<Loans>;
}

<div class="dashboard-wrapper">

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Total members</div>
                <div class="stat-value">@report.TotalMembers</div>
                <div class="stat-change text-success">+@report.NewMembersThisMonth this month</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Total savings</div>
                <div class="stat-value">UGX @report.TotalSavings.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Active loans</div>
                <div class="stat-value">@report.TotalActiveLoans</div>
                <div class="stat-change text-danger">@report.OverdueLoans overdue</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Loan book</div>
                <div class="stat-value">UGX @report.TotalLoanBook.ToString("N0")</div>
                <div class="stat-change text-success">
                    @(report.TotalLoanBook > 0
                                        ? ((report.TotalRepaid / report.TotalLoanBook) * 100).ToString("N0")
                                        : "0")% repaid
                </div>
            </div>
        </div>
    </div>

    <!-- Members table + Loans panel -->
    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="sacco-card">
                <div class="sacco-card-title">Recent members</div>
                @if (members == null || !members.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">M</div>
                        <div class="empty-text">No members yet</div>
                        <small class="text-muted">
                            <a href="/Members/Create">Add the first member</a>
                        </small>
                    </div>
                }
                else
                {
                    <table class="table table-borderless sacco-table">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Phone</th>
                                <th>Loan status</th>
                                <th>Joined</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in members)
                            {
                                var memberLoan = loans?.FirstOrDefault(l => l.MemberId == member.Id);
                                var badgeClass = memberLoan == null ? "badge-status-cleared"
                                : memberLoan.Status == "Overdue" ? "badge-status-overdue"
                                : "badge-status-active";
                                var badgeText = memberLoan == null ? "No loan"
                                : memberLoan.Status;

                                <tr>
                                    <td>
                                        <span class="avatar-pill">
                                            @member.FullName?.Substring(0, 1).ToUpper()
                                        </span>
                                        @member.FullName
                                    </td>
                                    <td>@member.Phone</td>
                                    <td>
                                        <span class="badge-status @badgeClass">@badgeText</span>
                                    </td>
                                    <td>@member.DateJoined.ToString("MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="col-md-4">
            <div class="sacco-card h-100">
                <div class="sacco-card-title">Active loans</div>
                @if (loans == null || !loans.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">L</div>
                        <div class="empty-text">No active loans</div>
                    </div>
                }
                else
                {
                    @foreach (var loan in loans)
                    {
                        var progress = loan.Amount > 0
                        ? (int)((loan.AmountRepaid / loan.Amount) * 100) : 0;
                        var barColor = loan.Status == "Overdue" ? "#E24B4A"
                        : loan.Status == "Cleared" ? "#1D9E75" : "#BA7517";
                        var badgeClass = loan.Status == "Overdue"
                        ? "badge-status-overdue" : "badge-status-active";

                        <div class="loan-item">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="loan-name">@loan.Member?.FullName</span>
                                <span class="badge-status @badgeClass">@loan.Status</span>
                            </div>
                            <small class="text-muted">
                                UGX @loan.Amount.ToString("N0") — @progress% repaid
                            </small>
                            <div class="progress mt-2" style="height:5px;">
                                <div class="progress-bar"
                                     style="width:@progress%;background:@barColor"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Recent activity -->
    <div class="sacco-card">
        <div class="sacco-card-title">Recent members activity</div>
        @if (members == null || !members.Any())
        {
            <p class="text-muted" style="font-size:13px;">No activity yet.</p>
        }
        else
        {
            <div class="activity-list">
                @foreach (var member in members)
                {
                    <div class="activity-row">
                        <span class="act-dot bg-primary"></span>
                        <div>
                            <div class="act-text">@member.FullName registered as a member</div>
                            <div class="act-time">@member.DateJoined.ToString("dd MMM yyyy, hh:mm tt")</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>