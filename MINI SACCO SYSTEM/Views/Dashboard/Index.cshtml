    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-wrapper">

    <!-- Top bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-semibold">Mini SACCO — Dashboard</h4>
            <small class="text-muted">Overview as of @DateTime.Now.ToString("MMMM yyyy")</small>
        </div>
        <a href="#" class="btn btn-sm btn-outline-primary">+ Add Member</a>
    </div>

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Total members</div>
                <div class="stat-value">24</div>
                <div class="stat-change text-success">+3 this month</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Total savings</div>
                <div class="stat-value">UGX 4.2M</div>
                <div class="stat-change text-success">+12% vs last month</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Active loans</div>
                <div class="stat-value">7</div>
                <div class="stat-change text-danger">2 overdue</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-label">Loan book</div>
                <div class="stat-value">UGX 1.8M</div>
                <div class="stat-change text-success">68% repaid on time</div>
            </div>
        </div>
    </div>

    <!-- Members table + Loans panel -->
    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="sacco-card">
                <div class="sacco-card-title">Members — savings overview</div>
                <table class="table table-borderless sacco-table">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Savings (UGX)</th>
                            <th>Loan status</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="avatar-pill">AK</span> Amara Kato</td>
                            <td>320,000</td>
                            <td><span class="badge bg-success-subtle text-success">Paid up</span></td>
                            <td>Jan 2025</td>
                        </tr>
                        <tr>
                            <td><span class="avatar-pill">BN</span> Brian Nkosi</td>
                            <td>185,000</td>
                            <td><span class="badge bg-warning-subtle text-warning">In repayment</span></td>
                            <td>Mar 2025</td>
                        </tr>
                        <tr>
                            <td><span class="avatar-pill">CM</span> Cynthia Mugisha</td>
                            <td>540,000</td>
                            <td><span class="badge bg-success-subtle text-success">No loan</span></td>
                            <td>Feb 2025</td>
                        </tr>
                        <tr>
                            <td><span class="avatar-pill">DO</span> David Okello</td>
                            <td>90,000</td>
                            <td><span class="badge bg-danger-subtle text-danger">Overdue</span></td>
                            <td>Jun 2025</td>
                        </tr>
                        <tr>
                            <td><span class="avatar-pill">EW</span> Esther Waweru</td>
                            <td>410,000</td>
                            <td><span class="badge bg-warning-subtle text-warning">In repayment</span></td>
                            <td>Apr 2025</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-4">
            <div class="sacco-card h-100">
                <div class="sacco-card-title">Active loans</div>

                <div class="loan-item">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="loan-name">Brian Nkosi</span>
                        <span class="badge bg-warning-subtle text-warning">Active</span>
                    </div>
                    <small class="text-muted">UGX 200,000 — 60% repaid</small>
                    <div class="progress mt-2" style="height:5px;">
                        <div class="progress-bar bg-success" style="width:60%"></div>
                    </div>
                </div>

                <div class="loan-item">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="loan-name">David Okello</span>
                        <span class="badge bg-danger-subtle text-danger">Overdue</span>
                    </div>
                    <small class="text-muted">UGX 150,000 — 20% repaid</small>
                    <div class="progress mt-2" style="height:5px;">
                        <div class="progress-bar bg-danger" style="width:20%"></div>
                    </div>
                </div>

                <div class="loan-item">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="loan-name">Esther Waweru</span>
                        <span class="badge bg-warning-subtle text-warning">Active</span>
                    </div>
                    <small class="text-muted">UGX 300,000 — 45% repaid</small>
                    <div class="progress mt-2" style="height:5px;">
                        <div class="progress-bar bg-warning" style="width:45%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent activity -->
    <div class="sacco-card">
        <div class="sacco-card-title">Recent activity</div>
        <div class="activity-list">
            <div class="activity-row">
                <span class="act-dot bg-success"></span>
                <div>
                    <div class="act-text">Cynthia Mugisha deposited UGX 50,000</div>
                    <div class="act-time">Today, 10:32 AM</div>
                </div>
            </div>
            <div class="activity-row">
                <span class="act-dot bg-primary"></span>
                <div>
                    <div class="act-text">New member registered — James Tendo</div>
                    <div class="act-time">Today, 9:15 AM</div>
                </div>
            </div>
            <div class="activity-row">
                <span class="act-dot bg-danger"></span>
                <div>
                    <div class="act-text">David Okello loan payment missed — 3 days overdue</div>
                    <div class="act-time">Yesterday, 11:00 PM</div>
                </div>
            </div>
            <div class="activity-row">
                <span class="act-dot bg-warning"></span>
                <div>
                    <div class="act-text">Brian Nkosi made loan repayment of UGX 20,000</div>
                    <div class="act-time">Yesterday, 2:45 PM</div>
                </div>
            </div>
        </div>
    </div>

</div>