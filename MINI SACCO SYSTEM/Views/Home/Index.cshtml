@{
    ViewData["Title"] = "Welcome";
    Layout = "_Layout";
}

<!-- Hero Section -->
<div style="background: linear-gradient(135deg, #1a3c5e 0%, #16324f 100%); color: white; padding: 100px 0; text-align: center;">
    <div class="container">
        <div style="width:64px; height:64px; background:#e8a838; border-radius:16px; display:flex; align-items:center; justify-content:center; margin: 0 auto 24px;">
            <span style="color:#1a3c5e; font-size:1.8rem; font-weight:700;">S</span>
        </div>
        <h1 style="font-size: 2.8rem; font-weight: 700; margin-bottom: 12px; letter-spacing:-0.5px;">Mini SACCO</h1>
        <p style="font-size: 1.1rem; opacity: 0.75; margin-bottom: 40px; font-style:italic;">
            Empowering members, one shilling at a time
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-area="Identity" asp-page="/Account/Login"
               style="background:#e8a838; color:#1a3c5e; padding: 12px 36px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 0.95rem;">
                Member Login
            </a>
            <a asp-area="Identity" asp-page="/Account/Register"
               style="background:transparent; color:white; padding: 12px 36px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 0.95rem; border: 2px solid rgba(255,255,255,0.4);">
                Join the SACCO
            </a>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div style="background:#f8f9fa; padding: 60px 0;">
    <div class="container">
        <p class="text-center text-muted mb-4" style="font-size:11px; text-transform:uppercase; letter-spacing:0.08em; font-weight:600;">SACCO AT A GLANCE</p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm text-center p-4">
                    <div style="font-size:1.6rem; margin-bottom:8px;">👥</div>
                    <div class="stat-value">@ViewBag.TotalMembers</div>
                    <div class="stat-label mt-1">Total Members</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm text-center p-4">
                    <div style="font-size:1.6rem; margin-bottom:8px;">💰</div>
                    <div class="stat-value">UGX @String.Format("{0:N0}", (decimal)ViewBag.TotalSavings)</div>
                    <div class="stat-label mt-1">Total Savings</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm text-center p-4">
                    <div style="font-size:1.6rem; margin-bottom:8px;">📋</div>
                    <div class="stat-value">@ViewBag.TotalLoans</div>
                    <div class="stat-label mt-1">Loans Issued</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm text-center p-4">
                    <div style="font-size:1.6rem; margin-bottom:8px;">🏧</div>
                    <div class="stat-value">UGX @String.Format("{0:N0}", (decimal)ViewBag.TotalDisbursed)</div>
                    <div class="stat-label mt-1">Total Disbursed</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- What members can do -->
<div style="padding: 70px 0;">
    <div class="container">
        <p class="text-center text-muted mb-2" style="font-size:11px; text-transform:uppercase; letter-spacing:0.08em; font-weight:600;">MEMBER BENEFITS</p>
        <h4 class="text-center fw-bold mb-5" style="color:#1a3c5e;">What you can do as a member</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 h-100 text-center" style="border-top: 3px solid #e8a838 !important;">
                    <div style="width:48px; height:48px; background:#faeeda; border-radius:12px; display:flex; align-items:center; justify-content:center; margin: 0 auto 16px; font-size:1.4rem;">
                        💳
                    </div>
                    <h6 class="fw-bold" style="color:#1a3c5e;">View Your Savings</h6>
                    <p class="text-muted small mt-2 mb-4">Track all your deposits, withdrawals and current balance in one place.</p>
                    <a asp-area="Identity" asp-page="/Account/Login"
                       class="btn btn-sm mt-auto"
                       style="background:#1a3c5e; color:white; border-radius:8px; font-size:12px; font-weight:600; padding: 8px 20px;">
                        Login to view
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 h-100 text-center" style="border-top: 3px solid #e8a838 !important;">
                    <div style="width:48px; height:48px; background:#faeeda; border-radius:12px; display:flex; align-items:center; justify-content:center; margin: 0 auto 16px; font-size:1.4rem;">
                        📄
                    </div>
                    <h6 class="fw-bold" style="color:#1a3c5e;">Apply for a Loan</h6>
                    <p class="text-muted small mt-2 mb-4">Access affordable loans and track your repayment schedule easily.</p>
                    <a asp-area="Identity" asp-page="/Account/Login"
                       class="btn btn-sm mt-auto"
                       style="background:#1a3c5e; color:white; border-radius:8px; font-size:12px; font-weight:600; padding: 8px 20px;">
                        Login to apply
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 h-100 text-center" style="border-top: 3px solid #e8a838 !important;">
                    <div style="width:48px; height:48px; background:#faeeda; border-radius:12px; display:flex; align-items:center; justify-content:center; margin: 0 auto 16px; font-size:1.4rem;">
                        📊
                    </div>
                    <h6 class="fw-bold" style="color:#1a3c5e;">Transaction History</h6>
                    <p class="text-muted small mt-2 mb-4">View your full transaction history and download statements anytime.</p>
                    <a asp-area="Identity" asp-page="/Account/Login"
                       class="btn btn-sm mt-auto"
                       style="background:#1a3c5e; color:white; border-radius:8px; font-size:12px; font-weight:600; padding: 8px 20px;">
                        Login to view
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bottom CTA -->
<div style="background: linear-gradient(135deg, #1a3c5e 0%, #16324f 100%); padding: 60px 0; text-align:center;">
    <div class="container">
        <h5 style="color:white; font-weight:700; margin-bottom:8px;">Not a member yet?</h5>
        <p style="color:rgba(255,255,255,0.65); font-size:0.9rem; margin-bottom:28px;">
            Join Mini SACCO today and start saving smarter.
        </p>
        <a asp-area="Identity" asp-page="/Account/Register"
           style="background:#e8a838; color:#1a3c5e; padding: 12px 36px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 0.95rem;">
            Register Now
        </a>
    </div>
</div>