@model IEnumerable<MINI_SACCO_SYSTEM.Models.Loans>
@{
    ViewData["Title"] = "My Loans";
}

<div class="dashboard-wrapper">
    <div class="mb-4">
        <h4 class="fw-bold mb-0" style="color:#1a3c5e;">Loans</h4>
        <small class="text-muted">Overview of your loan applications and status</small>
    </div>

    <div class="sacco-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">💸</div>
                <div class="empty-text">No loans found</div>
                <small class="text-muted">Your loan history will appear here</small>
            </div>
        }
        else
        {
            @foreach (var loan in Model)
            {
                <div style="display:flex; align-items:center; gap:14px; padding:14px 0; border-bottom:1px solid #f1f3f5;">
                    <div style="flex:1;">
                        <div style="font-size:14px; font-weight:600; color:#1a1a2e;">
                            Loan of UGX @loan.Amount.ToString("N0")
                        </div>
                        <div style="font-size:12px; color:#6c757d;">
                            Status: @loan.Status | Applied on: @loan.DateApplied.ToString("dd MMM yyyy")
                        </div>
                    </div>
                    @if (User.IsInRole("Admin") && loan.Status == "Pending")
                    {
                        <div>
                            <a asp-action="UpdateStatus" asp-route-id="@loan.Id" asp-route-status="Active" class="btn btn-sm btn-success">Approve</a>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>