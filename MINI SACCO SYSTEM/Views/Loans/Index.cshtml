@model List<MINI_SACCO_SYSTEM.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="dashboard-wrapper">
    <div class="mb-4">
        <h4 class="fw-bold mb-0" style="color:#1a3c5e;">Notifications</h4>
        <small class="text-muted">Your recent activity — all marked as read on open</small>
    </div>

    <div class="sacco-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🔔</div>
                <div class="empty-text">No notifications yet</div>
                <small class="text-muted">Activity will appear here as members deposit, withdraw and apply for loans</small>
            </div>
        }
        else
        {
            @foreach (var n in Model)
            {
                <a href="@n.Link" style="text-decoration:none;">
                    <div style="display:flex; align-items:flex-start; gap:14px; padding:14px 0; border-bottom:1px solid #f1f3f5; transition: background 0.2s;">
                        <div style="width:9px; height:9px; border-radius:50%;
                            background:@(n.IsRead ? "#dee2e6" : "#e8a838");
                            margin-top:5px; flex-shrink:0;">
                        </div>
                        <div style="flex:1;">
                            <div style="font-size:13px; color:#1a1a2e;
                                font-weight:@(n.IsRead ? "400" : "600");">
                                @n.Message
                            </div>
                            <div style="font-size:11px; color:#6c757d; margin-top:3px;">
                                @n.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                            </div>
                        </div>
                        <div>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="#6c757d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>