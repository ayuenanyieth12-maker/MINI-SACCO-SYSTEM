@model MINI_SACCO_SYSTEM.Models.Members

@{
    ViewData["Title"] = "Add Member";
}

<div class="dashboard-wrapper">
    <div class="mb-4">
        <h4 class="mb-0 fw-semibold">Add new member</h4>
        <small class="text-muted">Fill in the details to register a new SACCO member</small>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="sacco-card">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label sacco-label">Full name</label>
                        <input asp-for="FullName" class="form-control sacco-input"
                               placeholder="e.g. Amara Kato" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label sacco-label">Phone number</label>
                        <input asp-for="Phone" class="form-control sacco-input"
                               placeholder="e.g. 0712345678" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label sacco-label">Email address <span class="text-muted">(optional)</span></label>
                        <input asp-for="Email" class="form-control sacco-input"
                               placeholder="e.g. amara@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn sacco-btn-primary w-100">
                            Register member
                        </button>
                        <a href="/Members" class="btn btn-outline-secondary w-100">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>