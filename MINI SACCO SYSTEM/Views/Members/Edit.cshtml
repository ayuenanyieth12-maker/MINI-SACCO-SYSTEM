@model MINI_SACCO_SYSTEM.Models.Members

@{
    ViewData["Title"] = "Edit Member";
}

<div class="dashboard-wrapper">
    <div class="mb-4">
        <h4 class="mb-0 fw-semibold">Edit member</h4>
        <small class="text-muted">Update the member's details below</small>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="sacco-card">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="DateJoined" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label sacco-label">Full name</label>
                        <input asp-for="FullName" class="form-control sacco-input" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label sacco-label">Phone number</label>
                        <input asp-for="Phone" class="form-control sacco-input" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label sacco-label">Email address <span class="text-muted">(optional)</span></label>
                        <input asp-for="Email" class="form-control sacco-input" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn sacco-btn-primary w-100">
                            Save changes
                        </button>
                        <a href="/Members" class="btn btn-outline-secondary w-100">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>