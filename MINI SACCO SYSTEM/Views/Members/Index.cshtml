@model IEnumerable<MINI_SACCO_SYSTEM.Models.Members>

@{
    ViewData["Title"] = "Members";
}

<div class="dashboard-wrapper">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-semibold">Members</h4>
            <small class="text-muted">All registered SACCO members</small>
        </div>
        <a href="/Members/Create" class="btn btn-sm sacco-btn-primary">+ Add member</a>
    </div>

    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-label">Total members</div>
                <div class="stat-value">@Model.Count()</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-label">Joined this month</div>
                <div class="stat-value text-success">
                    @Model.Count(m => m.DateJoined.Month == DateTime.Now.Month
                        && m.DateJoined.Year == DateTime.Now.Year)
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-label">Joined this year</div>
                <div class="stat-value">
                    @Model.Count(m => m.DateJoined.Year == DateTime.Now.Year)
                </div>
            </div>
        </div>
    </div>

    <!-- Search bar -->
    <div class="mb-3">
        <input type="text" id="memberSearch"
               class="form-control sacco-input"
               placeholder="Search by name, phone or email..."
               style="max-width: 360px;" />
    </div>

    <!-- Members table -->
    <div class="sacco-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">M</div>
                <div class="empty-text">No members yet</div>
                <small class="text-muted">Click "+ Add member" to register the first one</small>
            </div>
        }
        else
        {
            <table class="table table-borderless sacco-table" id="membersTable">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Date joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model)
                    {
                        <tr class="member-row">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="avatar-pill">
                                        @member.FullName?.Substring(0, 1).ToUpper()
                                    </span>
                                    <span class="member-name">@member.FullName</span>
                                </div>
                            </td>
                            <td>@member.Phone</td>
                            <td>@(string.IsNullOrEmpty(member.Email) ? "—" : member.Email)</td>
                            <td>@member.DateJoined.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="/Members/Edit/@member.Id"
                                       class="action-btn action-btn-edit">Edit</a>
                                    <button class="action-btn action-btn-delete"
                                            onclick="confirmDelete(@member.Id, '@member.FullName')">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Delete confirmation modal -->
<div id="deleteModal" class="modal-backdrop-custom" style="display:none;">
    <div class="modal-box">
        <div class="modal-icon">!</div>
        <div class="modal-title">Delete member?</div>
        <div class="modal-sub" id="deleteModalText"></div>
        <div class="d-flex gap-2 mt-3">
            <a id="confirmDeleteBtn" href="#" class="btn sacco-btn-danger w-100">Yes, delete</a>
            <button onclick="closeModal()" class="btn btn-outline-secondary w-100">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('memberSearch').addEventListener('input', function() {
            const val = this.value.toLowerCase();
            document.querySelectorAll('.member-row').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
            });
        });

        function confirmDelete(id, name) {
            document.getElementById('deleteModalText').textContent =
                'Are you sure you want to delete ' + name + '? This cannot be undone.';
            document.getElementById('confirmDeleteBtn').href = '/Members/Delete/' + id;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('deleteModal').style.display = 'none';
        }
    </script>
}
