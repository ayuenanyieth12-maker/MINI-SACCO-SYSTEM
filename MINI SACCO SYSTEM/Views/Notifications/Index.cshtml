@model List<MINI_SACCO_SYSTEM.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="dashboard-wrapper">
    <div class="mb-4">
        <h4 class="fw-bold mb-0" style="color:#1a3c5e;">Notifications</h4>
        <small class="text-muted">Your recent activity</small>
    </div>

    <div class="sacco-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🔔</div>
                <div class="empty-text">No notifications yet</div>
                <small class="text-muted">Activity will appear here</small>
            </div>
        }
        else
        {
            @foreach (var n in Model)
            {
                <a href="@n.Link" style="text-decoration:none;">
                    <div style="display:flex; align-items:flex-start; gap:12px; padding:14px 0; border-bottom:1px solid #f1f3f5;">
                        <div style="width:8px; height:8px; border-radius:50%; background:@(n.IsRead ? "#dee2e6" : "#e8a838"); margin-top:6px; flex-shrink:0;"></div>
                        <div>
                            <div style="font-size:13px; color:#1a1a2e; font-weight:@(n.IsRead ? "400" : "600");">
                                @n.Message
                            </div>
                            <div style="font-size:11px; color:#6c757d; margin-top:3px;">
                                @n.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>