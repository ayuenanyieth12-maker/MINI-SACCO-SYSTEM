@model MINI_SACCO_SYSTEM.Models.Savings

@{
    ViewData["Title"] = "Deposit";
}

<div class="dashboard-wrapper">
    <div class="mb-4">
        <h4 class="mb-0 fw-semibold">Record deposit</h4>
        <small class="text-muted">Add a savings deposit for a member</small>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="sacco-card">
                <form asp-action="Deposit" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label sacco-label">Member</label>
                        <select asp-for="MemberId" asp-items="ViewBag.Members"
                                class="form-select sacco-input">
                            <option value="">— Select member —</option>
                        </select>
                        <span asp-validation-for="MemberId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label sacco-label">Amount (UGX)</label>
                        <input asp-for="Amount" type="number" min="1"
                               class="form-control sacco-input"
                               placeholder="e.g. 50000" />
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label sacco-label">Notes <span class="text-muted">(optional)</span></label>
                        <input asp-for="Notes" class="form-control sacco-input"
                               placeholder="e.g. Monthly contribution" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn sacco-btn-primary w-100">
                            Save deposit
                        </button>
                        <a href="/Savings" class="btn btn-outline-secondary w-100">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>