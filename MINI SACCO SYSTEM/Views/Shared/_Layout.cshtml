<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Mini SACCO</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @using Microsoft.AspNetCore.Identity
    @inject SignInManager<IdentityUser> SignInManager
    @inject UserManager<IdentityUser> UserManager

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sacco-navbar">
        <div class="container-fluid px-4">

            <a class="navbar-brand sacco-brand" href="/">
                <div class="brand-icon">S</div>
                <span>Mini SACCO</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-1">

                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Dashboard">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Members">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                Members
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Savings">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                                Savings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Loans">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></svg>
                                Loans
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Reports">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                                Reports
                            </a>
                        </li>
                    }
                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Member"))
                    {
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" asp-controller="MemberPortal" asp-action="Index">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                                My Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Savings">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                                My Savings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" href="/Loans">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                My Loans
                            </a>
                        </li>
                    }

                    <!-- Divider -->
                    <li class="nav-item"><div class="nav-divider"></div></li>

                    <!-- Bell icon — only for logged in users -->
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a href="/Notifications" class="nav-link sacco-nav-link position-relative" id="notifBell" style="padding: 6px 10px !important;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                                </svg>
                                <span id="notifCount"
                                      style="position:absolute; top:2px; right:2px; background:#e8a838; color:#1a3c5e;
                                    font-size:9px; font-weight:700; border-radius:50%; width:16px; height:16px;
                                    display:none; align-items:center; justify-content:center; line-height:1;">
                                    0
                                </span>
                            </a>
                        </li>
                    }
                    <!-- Auth area -->
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item dropdown">
                            <div class="nav-avatar dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer;" title="@User.Identity!.Name">
                                @User.Identity.Name![0].ToString().ToUpper()
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-item-text text-muted small">@User.Identity.Name</span></li>
                                <li><hr class="dropdown-divider" /></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item" href="/Dashboard">Admin Dashboard</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item" asp-controller="MemberPortal" asp-action="Index">My Portal</a></li>
                                }
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <!-- Public visitors see Login + Register -->
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sacco-nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- Page content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="sacco-footer">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center">
                <div class="footer-brand">
                    <div class="brand-icon brand-icon-sm">S</div>
                    <span>Mini SACCO &copy; @DateTime.Now.Year</span>
                </div>
                <div class="footer-tagline">Empowering members, one shilling at a time</div>
                <div class="footer-links">
                    <a>Privacy</a>
                    <a>Support</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (SignInManager.IsSignedIn(User))
    {
        <script>
                async function checkNotifications() {
                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                        const res = await fetch('/Notifications/GetUnreadCount', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            }
                        });
                        const data = await res.json();
                        const badge = document.getElementById('notifCount');
                        if (badge) {
                            if (data.count > 0) {
                                badge.textContent = data.count;
                                badge.style.display = 'flex';
                            } else {
                                badge.style.display = 'none';
                            }
                        }
                    } catch (e) {}
                }

                checkNotifications();
                setInterval(checkNotifications, 30000);
        </script>
    }

</body>
</html>